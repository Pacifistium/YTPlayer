<Window x:Class="YTPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YT Player" Height="640" Width="860"
        ResizeMode="CanResize" MinWidth="700" MinHeight="500"
        WindowStyle="SingleBorderWindow"
        Background="#0f0f0f"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#333333"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#444444"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Foreground" Value="#555555"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource CtrlBtn}">
            <Setter Property="Background" Value="#cc2222"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#dd3333"/></Trigger>
                <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#aa1111"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlayBtn" TargetType="Button" BasedOn="{StaticResource CtrlBtn}">
            <Setter Property="Background" Value="#cc2222"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#dd3333"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource CtrlBtn}">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="LoopBtn" TargetType="Button" BasedOn="{StaticResource SmallBtn}">
            <Setter Property="Background" Value="#222222"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="on">
                    <Setter Property="Background" Value="#1a5c1a"/>
                    <Setter Property="Foreground" Value="#44ee44"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#333333"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#cc2222" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <!-- Прозрачная хитзона 28px, видимый круг 14px -->
                                                <Grid Width="28" Height="28">
                                                    <Ellipse Width="28" Height="28" Fill="Transparent"/>
                                                    <Ellipse Width="14" Height="14" Fill="White"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Thumb}}" Value="True">
                                                                        <Setter Property="Width" Value="18"/>
                                                                        <Setter Property="Height" Value="18"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#333333" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- Стиль для элементов обеих ListBox -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#cc2222"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль активного трека в очереди -->
        <Style x:Key="QueueItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#1a3a1a"/>
                    <Setter Property="Foreground" Value="#44ee44"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#cc2222"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a2a2a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16,12,16,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ ЛЕВАЯ КОЛОНКА ═══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="YT Player" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="остановлено" FontSize="10" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#444444"/>
                </StackPanel>
            </Grid>

            <!-- Поле ввода -->
            <Border Grid.Row="1" Background="#1a1a1a" CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Ссылка на видео или плейлист" FontSize="9" Foreground="#555555" Margin="0,0,0,5"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UrlBox" Grid.Column="0"
                                 Background="#111111" Foreground="White" CaretBrush="White"
                                 BorderThickness="1" BorderBrush="#333333"
                                 Padding="10,7" FontSize="11" Margin="0,0,6,0"
                                 VerticalContentAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="#cc2222"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Button Grid.Column="1" Content="+ В очередь" Style="{StaticResource SmallBtn}" Margin="0,0,6,0" Click="AddCurrentToQueue_Click"/>
                        <Button Grid.Column="2" x:Name="PlayButton" Content="▶  Играть" Style="{StaticResource PlayBtn}" Click="PlayButton_Click"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Превью + название -->
            <Grid Grid.Row="2" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="ThumbnailPanel" Grid.Column="0" Visibility="Collapsed"
                        Width="80" Height="45" CornerRadius="4" Margin="0,0,10,0"
                        Background="#111111">
                    <Image x:Name="ThumbnailImage" Stretch="UniformToFill"/>
                </Border>
                <TextBlock x:Name="TitleText" Grid.Column="1"
                           Text="Ничего не играет" FontSize="11" Foreground="White"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
            </Grid>

            <!-- Прогресс-бар -->
            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TimePos" Grid.Column="0" Text="0:00" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider x:Name="ProgressSlider" Grid.Column="1"
                        Style="{StaticResource DarkSlider}"
                        Minimum="0" Maximum="1" Value="0"
                        VerticalAlignment="Center" IsEnabled="False"
                        ValueChanged="ProgressSlider_ValueChanged"
                        PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                        Thumb.DragStarted="ProgressSlider_DragStarted"
                        Thumb.DragCompleted="ProgressSlider_DragCompleted"/>
                <TextBlock x:Name="TimeDur" Grid.Column="2" Text="0:00" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- Кнопки управления -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,4">
                <Button Content="⏮ −60с" Style="{StaticResource CtrlBtn}" Margin="0,0,4,0" Click="Btn_Seek" Tag="-60"/>
                <Button Content="◀ −10с" Style="{StaticResource CtrlBtn}" Margin="0,0,4,0" Click="Btn_Seek" Tag="-10"/>
                <Button x:Name="PauseButton" Content="⏸  Пауза" Style="{StaticResource AccentBtn}" Margin="0,0,4,0" Click="PauseButton_Click" MinWidth="90"/>
                <Button Content="+10с ▶" Style="{StaticResource CtrlBtn}" Margin="0,0,4,0" Click="Btn_Seek" Tag="10"/>
                <Button Content="+60с ⏭" Style="{StaticResource CtrlBtn}" Margin="0,0,8,0" Click="Btn_Seek" Tag="60"/>
                <Button Content="⏹ Стоп" Style="{StaticResource CtrlBtn}" Margin="0,0,8,0" Click="StopButton_Click"/>
                <Button x:Name="LoopButton" Content="🔁 Цикл" Style="{StaticResource LoopBtn}" Click="LoopButton_Click" Tag="off"/>
                <!-- Кнопки пред/след трек -->
                <Button Content="⏮" Style="{StaticResource SmallBtn}" Margin="8,0,4,0" Click="BtnPrev_Click" ToolTip="Предыдущий трек (P)"/>
                <Button Content="⏭" Style="{StaticResource SmallBtn}" Margin="0,0,0,0" Click="BtnNext_Click" ToolTip="Следующий трек (N)"/>
            </StackPanel>


            <!-- Громкость -->
            <Grid Grid.Row="5" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🔊" FontSize="13" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider x:Name="VolumeSlider" Grid.Column="1"
                        Style="{StaticResource DarkSlider}"
                        Minimum="0" Maximum="130" Value="80"
                        VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged"
                        MouseWheel="VolumeSlider_MouseWheel"/>
                <TextBlock x:Name="VolumeText" Grid.Column="2" Text="80%" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="8,0,0,0" Width="32"/>
            </Grid>

            <!-- Лог (свёртываемый) -->
            <Grid Grid.Row="7" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ToggleButton x:Name="LogToggle" Grid.Row="0"
                              Content="▼  Отладка" Tag="collapsed"
                              HorizontalAlignment="Left" Padding="8,3"
                              FontSize="10" Foreground="#444444" Background="Transparent"
                              BorderThickness="0" Cursor="Hand"
                              Checked="LogToggle_Checked" Unchecked="LogToggle_Unchecked"/>
                <TextBox x:Name="LogBox" Grid.Row="1"
                         Background="#0a0a0a" Foreground="#44cc77"
                         FontFamily="Consolas" FontSize="9"
                         BorderThickness="0" IsReadOnly="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         MaxHeight="110" Margin="0,2,0,0"
                         Visibility="Collapsed"/>
            </Grid>
        </Grid>

        <!-- ═══ ПРАВАЯ КОЛОНКА ═══ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="190"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Поиск -->
            <TextBlock Grid.Row="0" Text="ПОИСК YOUTUBE" FontSize="9" Foreground="#555555" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Grid.Column="0"
                             Background="#111111" Foreground="White" CaretBrush="White"
                             BorderThickness="1" BorderBrush="#333333"
                             Padding="8,6" FontSize="11" Margin="0,0,5,0"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#cc2222"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button x:Name="SearchButton" Grid.Column="1" Content="🔍" Style="{StaticResource SmallBtn}" Click="SearchButton_Click"/>
                </Grid>
                <ListBox x:Name="SearchResultsList" Grid.Row="1"
                         MouseDoubleClick="SearchResultsList_MouseDoubleClick"/>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,10">
                <Button Content="▶ Играть" Style="{StaticResource SmallBtn}" Margin="0,0,4,0" Click="SearchPlay_Click"/>
                <Button Content="+ В очередь" Style="{StaticResource SmallBtn}" Click="AddToQueueFromSearch_Click"/>
            </StackPanel>

            <!-- Очередь -->
            <TextBlock Grid.Row="3" Text="ОЧЕРЕДЬ" FontSize="9" Foreground="#555555" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox x:Name="QueueList" Grid.Row="4"
                     MouseDoubleClick="QueueList_MouseDoubleClick"
                     ItemContainerStyle="{StaticResource QueueItemStyle}"/>

            <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="✕ Удалить" Style="{StaticResource SmallBtn}" Margin="0,0,4,0" Click="QueueRemove_Click"/>
                <Button Content="🗑 Очистить" Style="{StaticResource SmallBtn}" Click="QueueClear_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
